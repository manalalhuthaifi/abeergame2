<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مغامرات عبير</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">

<style>
body{
    margin:0;
    font-family:'Cairo';
    background:#000;
}

/* شاشة البداية */
.start-bg{
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;

    background:url("./assets/bg.jpg") center/cover no-repeat;
    position:relative;
}

/* طبقة تغميق */
.start-bg::before{
    content:"";
    position:absolute;
    inset:0;
    background:linear-gradient(
        to top,
        rgba(0,0,0,0.85),
        rgba(0,0,0,0.5),
        rgba(0,0,0,0.2)
    );
}

/* عناصر فوق الخلفية */
.start-bg *{
    position:relative;
    z-index:2;
}

/* حركة للخلفية */
.start-bg{
    animation:zoomBg 12s infinite alternate ease-in-out;
}

@keyframes zoomBg{
    from{background-size:100%;}
    to{background-size:110%;}
}

/* النص */
h1{
    font-size:3.5rem;
    margin-bottom:10px;
    text-shadow:0 10px 25px rgba(0,0,0,0.8);
}

h2{
    margin-bottom:30px;
    text-shadow:0 5px 15px rgba(0,0,0,0.7);
}

/* الزر */
button{
    padding:18px 40px;
    font-size:1.5rem;
    border:none;
    border-radius:40px;
    background:#2e7d32;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:scale(1.1);
    background:#43a047;
}

/* صورة عبير */
.character{
    width:220px;
    margin-bottom:20px;
    filter:drop-shadow(0 20px 25px rgba(0,0,0,0.5));
    animation:float 3s infinite ease-in-out;
}

@keyframes float{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(-15px);}
}
</style>
</head>

<body>

<div class="start-bg">
    <div>
        <img src="./assets/abeer.png" class="character">
        <h1>مغامرات الكشافة عبير</h1>
        <h2>تحدي الحروف الكشفية</h2>

        <button onclick="startGame()">ابدأ اللعب ▶</button>
    </div>
</div>

<script>
function startGame(){
    alert("هنا تبدأ اللعبة 🎮 (اربطيه بالكود القديم)");
}
</script>

</body>
</html>
